{#
| Variable                | Type    | Description                                  |
|-------------------------|---------|----------------------------------------------|
| component              | object  | Component settings from twilight.json         |
#}

<section class="about-us-section py-16 relative overflow-hidden">
    <div class="container mx-auto px-4">
        <div class="flex flex-col md:flex-row items-center justify-between gap-10">
            <div class="md:w-1/2 order-2 md:order-2">
                {% if component.image_url %}
                    <div class="about-us-image-container relative">
                        <img src="{{ component.image_url }}"
                             alt="{{ component.title }}"
                             class="w-full h-auto rounded-lg shadow-lg">
                        {% if component.show_pattern %}
                            <div class="pattern-overlay absolute -bottom-10 -right-10 w-1/2 h-1/2 opacity-70 z-[1] pointer-events-none"></div>
                        {% endif %}
                    </div>
                {% endif %}
            </div>

            <div class="md:w-1/2 order-1 md:order-1 text-left">
                {% if component.small_title %}
                    <h3 class="text-sm font-semibold mb-2 text-gray-600">{{ component.small_title }}</h3>
                {% endif %}

                {% if component.title %}
                    <h2 class="text-3xl md:text-4xl font-bold mb-6 leading-relaxed">{{ component.title }}</h2>
                {% endif %}

                {% if component.description %}
                    <div class="mb-8 text-gray-700 leading-relaxed">
                        {{ component.description|raw }}
                    </div>
                {% endif %}

                {% if component.button_text and component.button_url %}
                    <a href="{{ component.button_url }}"
                       style="background-color: var(--color-primary)"
                       class="inline-block px-6 py-3 text-white rounded-md hover:opacity-90 transition duration-300">
                        {{ component.button_text }}
                    </a>
                {% endif %}
            </div>
        </div>
    </div>
</section>

{% if component.add_styles %}
<style>
    .about-us-section {
        background-color: {{ component.background_color|default('var(--site-bg-color, #f4f3e5)') }};
    }

    .pattern-overlay {
        background-image: url('{{ component.pattern_url|default('https://cdn.salla.sa/theme-safwa/pattern.png') }}');
        background-size: cover;
        background-repeat: no-repeat;
    }
</style>
{% endif %}
